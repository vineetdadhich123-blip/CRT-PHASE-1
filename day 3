//problem 5
//print 1 to 10 using for do -while loop
#include <iostream>
using namespace std;

int main() {
    int i=1;
    do{
        cout<<i<<"";
        i++;
    }while(i<=10);
    
    
}

//problem  6
// factorial of a number

#include <iostream>
using namespace std;

int main() {
    int n;
    cin>>n;
    int fact=1;
    for(int i=n;i>=1;i--){
        fact=fact*i;
        
    }cout<<fact;
}


//problem 7 
// prime and not prime number
#include <iostream>
using namespace std;

int main(){
    int n;
    cin>>n;
    bool isprime =true;
    
    if(n<2){
        isprime =false;
    
    }else{
        
    
    for(int i=2;i<n;i++){
        if(n%i==0){
            isprime=false;
            break;
        }
            
        }
        
        
    }
    if(isprime){
        cout<<"it is a prime number..";
        
    }else{
        cout<<"it is not  a prime number...";
    }
        
    
}

